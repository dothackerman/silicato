# Copy to .env and fill with real values locally.

HF_TOKEN=hf_xxx

# Optional: GitHub CLI token for non-interactive workflow dispatch (`gh`).
# If `gh auth login` is already configured, this can stay unset.
GH_TOKEN=ghp_xxx

# Break-glass local publishing credentials.
# Normal release flow uses Trusted Publishing in GitHub Actions, not local twine tokens.
TEST_PYPI_TOKEN=pypi-xxx
PYPI_TOKEN=pypi-xxx
